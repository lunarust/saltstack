upstream graylog {
        server {{ salt['grains.get']('fqdn_ip4')[0] }}:{{ salt['pillar.get']('graylog_container_port') }}; # for  redirection to docker image
}

server {

        listen       {{ salt['pillar.get']('graylog_nginx_ssl_port') }} ssl;
        server_name  {{ salt['grains.get']('fqdn_ip4')[0] }} {{ salt['grains.get']('fqdn') }} graylog.greece.local localhost;
        charset      utf-8;

        access_log                /var/log/nginx/nginx_graylog.access.log;
        error_log                 /var/log/nginx/nginx_graylog.errors.log info;

        #ssl on;
        ssl_certificate            /etc/nginx/ssl/cert.pem;
        ssl_certificate_key        /etc/nginx/ssl/key.pem;

        ssl_session_timeout        5m;
        ssl_prefer_server_ciphers  on;
        ssl_session_cache          shared:SSL:5m;
        ssl_protocols              TLSv1.2 TLSv1.3;

        location /
        {
            proxy_pass            http://graylog;
            proxy_redirect        off;
            proxy_set_header      Host            $http_host;
            proxy_set_header      X-Real-IP       $remote_addr;
            proxy_set_header      X_Forwarded-For $proxy_add_x_forwarded_for;
            proxy_connect_timeout 600;
            proxy_read_timeout    600;
            proxy_send_timeout    600;

            # access_log on;
            access_log   /var/log/nginx/nginx_graylog_container.access.log;
            error_log   /var/log/nginx/nginx_graylog_container.errors.log info;
        }

        location ~ /\. {
            deny  all;
        }
}
